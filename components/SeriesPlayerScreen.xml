<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesPlayerScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="setResumePosition" />
        <function name="getPlaybackPosition" />
        <function name="getPlaybackDuration" />
        <function name="closeSeriesPlayer" />
        <function name="hide" />
        <function name="showError" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesPlayerScreen.brs" />
    <children>
        <Rectangle id="cleanBackground" color="#000000" translation="[0, 0]" width="1280" height="720" />
        <Video id="video" translation="[0, 0]" visible="false" />
        <Group id="loadingGroup" visible="false">
            <BusySpinner id="loadingSpinner" />
            <Label id="loadingLabel" text="Carregando episódio..." color="#FFFFFF" horizAlign="center" />
        </Group>
        <Group id="controlsGroup" visible="false">
            <Rectangle id="controlsBackground" color="#000000" opacity="0.62" />
            <Label id="playPauseIcon" text="II" color="#FFFFFF" horizAlign="center" vertAlign="center" />
            <Label id="currentTimeLabel" text="00:00" color="#FFFFFF" horizAlign="left" />
            <Rectangle id="progressBackground" color="#5B6472" opacity="0.85" />
            <Rectangle id="progressFill" color="#FFFFFF" opacity="1" />
            <Label id="durationLabel" text="00:00" color="#FFFFFF" horizAlign="right" />
        </Group>
        <Timer id="progressUpdateTimer" duration="0.5" repeat="true" />
        <Timer id="seekHoldTimer" duration="0.35" repeat="true" />
        <Timer id="controlsAutoHideTimer" duration="3" repeat="false" />
        <Group id="errorGroup" visible="false">
            <Label id="errorTitle" text="Não foi possível reproduzir o episódio" color="#FFFFFF" horizAlign="center" />
            <Label id="errorMessage" text="Pressione Voltar e tente novamente." color="#B8C3D6" horizAlign="center" wrap="true" />
        </Group>
    </children>
</component>
