<?xml version="1.0" encoding="utf-8" ?>
<component name="LiveCategoriesScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setCategories" />
        <function name="showMessage" />
        <function name="selectCategory" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
        <field id="searchRequested" type="boolean" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/LiveCategoriesScreen.brs" />
    <children>
        <Rectangle id="background" color="#05070B" opacity="0.58" translation="[0, 0]" />
        <Label id="title" text="TV AO VIVO" color="#FFFFFF" horizAlign="center" />
        <Rectangle id="leftPanel" color="#0B111B" opacity="0.82" />
        <Rectangle id="rightPanel" color="#0B111B" opacity="0.82" />
        <Label id="categoriesTitle" text="Categorias" color="#FFFFFF" />
        <Label id="channelsTitle" text="Canais" color="#FFFFFF" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="categoriesGroup" />
        <Label id="emptyChannelsLabel" text="Selecione uma categoria" color="#7D8CA3" horizAlign="center" />
        <Label id="hintLabel" text="↑/↓ navegar • OK selecionar • Voltar para Home" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
