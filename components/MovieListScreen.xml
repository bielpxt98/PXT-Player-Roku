<?xml version="1.0" encoding="utf-8" ?>
<component name="MovieListScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setMovies" />
        <function name="showMessage" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="movieSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/MovieListScreen.brs" />
    <children>
        <Rectangle id="background" color="#000000" translation="[0, 0]" />
        <Label id="title" text="FILMES" color="#FFFFFF" horizAlign="center" />
        <Label id="subtitle" text="Filmes" color="#B8C3D6" horizAlign="center" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="moviesGroup" />
        <Label id="hintLabel" text="Use ↑/↓ para navegar • OK para assistir • Voltar para categorias" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
