<?xml version="1.0" encoding="utf-8" ?>
<component name="MovieListScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setMovies" />
        <function name="setCategories" />
        <function name="showMessage" />
        <function name="resetSelection" />
        <function name="focusCategories" />
        <function name="getState" />
        <function name="restoreState" />
        <function name="getSelectedIndex" />
        <function name="getFirstVisibleIndex" />
        <function name="restoreMovieSelection" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
        <field id="searchRequested" type="boolean" alwaysNotify="true" />
        <field id="movieSelected" type="assocarray" alwaysNotify="true" />
        <field id="movieFavoriteToggled" type="assocarray" alwaysNotify="true" />
