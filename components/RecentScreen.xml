<?xml version="1.0" encoding="utf-8" ?>
<component name="RecentScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setHistory" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/RecentScreen.brs" />
    <children>
        <Rectangle id="background" color="#000000" translation="[0, 0]" />
        <Label id="title" text="ÚLTIMOS ASSISTIDOS" color="#FFFFFF" horizAlign="center" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="itemsGroup" />
        <Label id="hintLabel" text="Voltar para Home" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
