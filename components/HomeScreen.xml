<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="updateConnectionStatus" />
        <field id="openLogin" type="boolean" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/HomeScreen.brs" />
    <children>
        <Rectangle id="homeBackground" color="#000000" translation="[0, 0]" />
        <Label id="homeTitle" text="PXT PLAYER" color="#FFFFFF" horizAlign="center" />
        <Label id="homeSubtitle" text="Sua central de IPTV para Roku" color="#B8C3D6" horizAlign="center" />
        <Label id="connectionStatusLabel" text="Nenhuma conexão ativa" color="#FFCC66" horizAlign="center" />

        <Group id="homeMenuGroup">
            <Button id="liveTvButton" text="TV AO VIVO" minWidth="420" />
            <Button id="moviesButton" text="FILMES" minWidth="420" translation="[0, 86]" />
            <Button id="seriesButton" text="SÉRIES" minWidth="420" translation="[0, 172]" />
            <Button id="playlistButton" text="LISTA DE REPRODUÇÃO" minWidth="420" translation="[0, 258]" />
        </Group>
    </children>
</component>
