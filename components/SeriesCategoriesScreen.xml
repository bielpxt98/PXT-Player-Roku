<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesCategoriesScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setCategories" />
        <function name="showMessage" />
        <function name="resetSelection" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesCategoriesScreen.brs" />
    <children>
        <Rectangle id="background" color="#000000" translation="[0, 0]" />
        <Label id="title" text="SÉRIES" color="#FFFFFF" horizAlign="center" />
        <Label id="subtitle" text="Categorias" color="#B8C3D6" horizAlign="center" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="categoriesGroup" />
        <Label id="hintLabel" text="Use ↑/↓ para navegar • OK para selecionar • Voltar para Home" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
