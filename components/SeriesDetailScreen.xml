<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesDetailScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setDetails" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="playRequested" type="boolean" alwaysNotify="true" />
        <field id="favoriteToggled" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesDetailScreen.brs" />
    <children>
        <Rectangle id="background" color="#070A12" translation="[0,0]" />
        <Poster id="poster" loadDisplayMode="scaleToFill" />
        <Label id="titleLabel" color="#FFFFFF" wrap="true" />
        <Label id="ratingLabel" color="#FFD166" />
        <Label id="genreLabel" color="#B8C3D6" wrap="true" />
        <Label id="synopsisLabel" color="#D1D5DB" wrap="true" />
        <Rectangle id="buttonBg" color="#0B3A5E" opacity="1.0" />
        <Label id="seasonsButton" text="TEMPORADAS" color="#FFFFFF" horizAlign="center" vertAlign="center" />
        <Label id="statusLabel" text="" color="#93A4B8" horizAlign="center" />
        <Label id="hintLabel" text="OK temporadas • * favoritar • Voltar" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
