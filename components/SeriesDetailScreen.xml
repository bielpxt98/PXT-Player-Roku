<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesDetailScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setDetails" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="playRequested" type="boolean" alwaysNotify="true" />
        <field id="episodeSelected" type="assocarray" alwaysNotify="true" />
        <field id="favoriteToggled" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesDetailScreen.brs" />
    <children>
        <Rectangle id="background" color="#070A12" translation="[0,0]" />
        <Poster id="poster" loadDisplayMode="scaleToFit" />
        <Label id="titleLabel" color="#FFFFFF" wrap="true" />
        <Label id="metaLabel" color="#B8C3D6" wrap="true" />
        <Label id="ratingLabel" color="#FFD166" />
        <Label id="synopsisLabel" color="#D1D5DB" wrap="true" />
        <Label id="episodesTitle" text="EPISÓDIOS" color="#FFFFFF" />
        <Label id="episodesStatus" color="#93A4B8" />
        <Group id="episodesGroup" />
        <Group id="buttonsGroup">
            <Label id="watchButton" color="#FFFFFF" horizAlign="center" vertAlign="center" />
            <Label id="continueButton" text="CONTINUAR" color="#FFFFFF" horizAlign="center" vertAlign="center" />
            <Label id="backButton" text="VOLTAR" color="#FFFFFF" horizAlign="center" vertAlign="center" />
        </Group>
    </children>
</component>
