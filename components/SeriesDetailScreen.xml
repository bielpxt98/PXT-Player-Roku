<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesDetailScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setDetails" />
        <function name="setLoading" />
        <function name="showMessage" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="episodeSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesDetailScreen.brs" />
    <children>
        <Rectangle id="panelBg" color="#08111F" opacity="0.94" />
        <Label id="backLabel" text="← VOLTAR" color="#FFFFFF" />
        <Label id="brandLabel" text="PXT PLAYER" color="#FFFFFF" horizAlign="right" />
        <Rectangle id="headerLine" color="#263244" height="2" />
        <Poster id="poster" loadDisplayMode="scaleToFill" />
        <Label id="titleLabel" color="#FFFFFF" />
        <Label id="genreLabel" color="#D7E2F1" />
        <Label id="yearLabel" color="#D7E2F1" />
        <Label id="ratingLabel" color="#D7E2F1" />
        <Label id="synopsisTitle" text="Sinopse:" color="#FFFFFF" />
        <Label id="synopsisLabel" color="#C8D4E4" wrap="true" maxLines="4" />
        <Rectangle id="seasonLine" color="#263244" height="2" />
        <Label id="seasonsTitle" text="TEMPORADAS" color="#FFFFFF" />
        <Group id="seasonsGroup" />
        <Rectangle id="episodesLine" color="#263244" height="2" />
        <Label id="episodesTitle" text="EPISÓDIOS" color="#FFFFFF" />
        <Group id="episodesGroup" />
        <Label id="messageLabel" color="#AAB8CC" horizAlign="center" />
        <Label id="hintLabel" text="OK assistir episódio • ←/→ trocar área • Voltar" color="#91A3BA" horizAlign="center" />
    </children>
</component>
