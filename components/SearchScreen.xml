<?xml version="1.0" encoding="utf-8" ?>
<component name="SearchScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setData" />
        <function name="showMessage" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="channelSelected" type="assocarray" alwaysNotify="true" />
        <field id="movieSelected" type="assocarray" alwaysNotify="true" />
        <field id="seriesSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/components/SearchScreen.brs" />
    <children>
        <Poster id="backgroundImage" uri="pkg:/images/background.jpeg" opacity="0" loadDisplayMode="scaleToFill" translation="[0, 0]" />
        <Rectangle id="overlay" color="#02040A" opacity="0.82" translation="[0, 0]" />
        <Rectangle id="topGradient" color="#000000" opacity="0.34" translation="[0, 0]" />
        <Label id="title" text="BUSCA" color="#FFFFFF" horizAlign="center" />
        <Label id="subtitle" text="Busca PXT Player" color="#B8C3D6" horizAlign="center" />
        <Rectangle id="inputBackground" color="#0B1220" opacity="0.92" />
        <TextEditBox id="searchInput" hintText="Digite no controle ou no app Roku Remote" text="" clearOnDownKey="false" />
        <Label id="queryMirror" text="" color="#FFFFFF" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Timer id="searchDebounceTimer" duration="0.4" repeat="false" />
        <Timer id="moviePreloadTimer" duration="0.01" repeat="true" />
        <Group id="keyboardGroup" focusable="true" />
        <Label id="resultsTitle" text="RESULTADOS EM GRADE" color="#D7E2F4" />
        <Group id="resultsGroup" />
        <Label id="hintLabel" text="←/→ navega • ↑ sobe para resultados • 123/ABC alterna letras e números • OK seleciona • Voltar retorna" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
