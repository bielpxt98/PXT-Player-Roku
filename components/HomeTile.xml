<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeTile" extends="Group">
    <interface>
        <field id="title" type="string" onChange="onTitleChanged" />
        <field id="imageUri" type="uri" onChange="onImageUriChanged" />
        <field id="iconUri" type="uri" onChange="onIconUriChanged" />
        <field id="iconText" type="string" onChange="onIconTextChanged" />
        <field id="baseColor" type="string" onChange="onBaseColorChanged" />
        <field id="focused" type="boolean" value="false" onChange="onFocusedChanged" />
        <field id="selected" type="boolean" value="false" onChange="onSelectedChanged" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/HomeTile.brs" />

    <children>
        <Rectangle id="outerGlow" width="318" height="226" color="#FFFFFF" opacity="0" translation="[-12, -12]" />
        <Group id="tileGroup" scaleRotateCenter="[147, 101]">
            <Rectangle id="tileShadow" width="294" height="202" color="#000000" opacity="0.52" translation="[8, 10]" />
            <Rectangle id="tileBorder" width="294" height="202" color="#FFFFFF" opacity="0.16" />
            <Rectangle id="tileFill" width="286" height="194" color="#101827" opacity="0.94" translation="[4, 4]" />
            <Poster id="tileImage" width="286" height="194" translation="[4, 4]" loadDisplayMode="scaleToFill" />
            <Rectangle id="tileFocusOverlay" width="286" height="194" color="#FFFFFF" opacity="0" translation="[4, 4]" />
            <Poster id="tileIcon" width="82" height="82" translation="[106, 36]" loadDisplayMode="scaleToFit" visible="false" />
            <Label id="tileIconText" width="294" height="92" translation="[0, 30]" horizAlign="center" vertAlign="center" color="#FFFFFF" visible="false" />
            <Label id="tileTitle" width="264" height="46" translation="[15, 136]" horizAlign="center" vertAlign="center" color="#FFFFFF" visible="false" />
        </Group>

        <Animation id="focusInAnimation" duration="0.18" easeFunction="outQuad">
            <Vector2DFieldInterpolator key="[0.0, 1.0]" keyValue="[[1.0, 1.0], [1.07, 1.07]]" fieldToInterp="tileGroup.scale" />
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.0, 0.42]" fieldToInterp="outerGlow.opacity" />
        </Animation>

        <Animation id="focusOutAnimation" duration="0.14" easeFunction="outQuad">
            <Vector2DFieldInterpolator key="[0.0, 1.0]" keyValue="[[1.07, 1.07], [1.0, 1.0]]" fieldToInterp="tileGroup.scale" />
            <FloatFieldInterpolator key="[0.0, 1.0]" keyValue="[0.42, 0.0]" fieldToInterp="outerGlow.opacity" />
        </Animation>
    </children>
</component>
