<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesSearchScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setSeries" />
        <function name="showMessage" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="seriesSelected" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesSearchScreen.brs" />
    <children>
        <Rectangle id="overlay" color="#02040A" opacity="0.92" translation="[0, 0]" />
        <Label id="title" text="PESQUISAR" color="#FFFFFF" horizAlign="center" />
        <Rectangle id="inputBackground" color="#0B1220" opacity="0.95" />
        <Label id="queryLabel" text="Buscar: " color="#FFFFFF" />
        <Label id="messageLabel" text="" color="#FFCC66" horizAlign="center" />
        <Group id="resultsGroup" />
        <Group id="keyboardGroup" />
        <Label id="hintLabel" text="OK seleciona • Cima/Baixo navega linha a linha • Voltar fecha" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
