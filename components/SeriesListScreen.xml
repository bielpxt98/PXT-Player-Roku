<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesListScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setSeries" />
        <function name="setCategories" />
        <function name="showMessage" />
        <function name="resetSelection" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
        <field id="searchRequested" type="boolean" alwaysNotify="true" />
        <field id="seriesSelected" type="assocarray" alwaysNotify="true" />
        <field id="seriesFavoriteToggled" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/SeriesListScreen.brs" />
    <children>
        <Rectangle id="background" color="#05070B" translation="[0, 0]" />
        <Rectangle id="searchBar" color="#101722" opacity="0.96" />
        <Label id="searchLabel" text="Pesquisar" color="#DDE6F3" vertAlign="center" />
        <Rectangle id="leftPanel" color="#0B111B" opacity="0.98" />
        <Rectangle id="divider" color="#1D2A3A" />
        <Label id="categoriesTitle" text="Categorias" color="#FFFFFF" />
        <Label id="subtitle" text="SÉRIES" color="#9FAEC4" horizAlign="right" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="categoriesGroup" />
        <Group id="seriesGroup" />
        <Label id="hintLabel" text="←/→ alternar painel • OK selecionar • * favoritar • Voltar" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
