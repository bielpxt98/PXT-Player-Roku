<?xml version="1.0" encoding="utf-8" ?>
<component name="MovieSearchScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setMovies" />
        <function name="showMessage" />
        <function name="setCatalogLoading" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="movieSelected" type="assocarray" alwaysNotify="true" />
        <field id="loadMoreRequested" type="string" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/MovieSearchScreen.brs" />
    <children>
        <Rectangle id="overlay" color="#02040A" opacity="0.92" translation="[0, 0]" />
        <Label id="title" text="PESQUISAR FILME" color="#FFFFFF" horizAlign="center" />
        <Rectangle id="inputBackground" color="#0B1220" opacity="0.95" />
        <Label id="queryLabel" text="Buscar: " color="#FFFFFF" />
        <Label id="messageLabel" text="" color="#FFCC66" horizAlign="center" />
        <Group id="resultsGroup" />
        <Group id="keyboardGroup" />
        <Label id="hintLabel" text="OK seleciona • Cima vai aos posters • Baixo volta ao teclado • Voltar fecha" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
