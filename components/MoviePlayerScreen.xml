<?xml version="1.0" encoding="utf-8" ?>
<component name="MoviePlayerScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="play" />
        <function name="setResumePosition" />
        <function name="getPlaybackPosition" />
        <function name="hide" />
        <function name="showError" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="movieName" type="string" />
    </interface>
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="pkg:/components/MoviePlayerScreen.brs" />
    <children>
        <Video id="video" translation="[0, 0]" showPlaybackInfo="false" />
        <Group id="loadingGroup" visible="false">
            <BusySpinner id="loadingSpinner" width="60" height="60" />
            <Label id="loadingLabel" text="Carregando filme..." color="#FFFFFF" horizAlign="center" />
        </Group>
        <Group id="controlsGroup" visible="false">
            <Rectangle id="controlsBackground" color="#05070B" opacity="0.86" />
            <Label id="controlsTitle" text="" color="#FFFFFF" />
            <Label id="seekStatusLabel" text="" color="#9FD8FF" horizAlign="center" />
            <Label id="currentTimeLabel" text="00:00" color="#FFFFFF" />
            <Label id="durationLabel" text="00:00" color="#FFFFFF" horizAlign="right" />
            <Rectangle id="progressTrack" color="#314155" />
            <Rectangle id="progressFill" color="#FFFFFF" />
        </Group>
        <Timer id="seekHoldTimer" duration="0.35" repeat="true" />
        <Timer id="progressTimer" duration="0.5" repeat="true" />
        <Group id="errorGroup" visible="false">
            <Label id="errorTitle" text="Não foi possível reproduzir o filme" color="#FFFFFF" horizAlign="center" />
            <Label id="errorMessage" text="Pressione Voltar e tente novamente." color="#B8C3D6" horizAlign="center" wrap="true" />
        </Group>
    </children>
</component>
