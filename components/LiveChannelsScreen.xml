<?xml version="1.0" encoding="utf-8" ?>
<component name="LiveChannelsScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setLoading" />
        <function name="setChannels" />
        <function name="showMessage" />
        <function name="setCategories" />
        <function name="setAccount" />
        <function name="resetSelection" />
        <function name="focusCategories" />
        <function name="focusChannels" />
        <function name="restoreSelectedChannel" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="channelSelected" type="assocarray" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
        <field id="searchRequested" type="boolean" alwaysNotify="true" />
        <field id="channelFavoriteToggled" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/LiveChannelsScreen.brs" />
    <children>
        <Rectangle id="background" color="#000000" opacity="0.58" translation="[0, 0]" />
        <Rectangle id="topBar" color="#07111F" opacity="0.82" />
        <Label id="currentCategoryLabel" text="Categoria Atual" color="#FFFFFF" horizAlign="left" vertAlign="center" />
        <Label id="dateLabel" text="" color="#B8C3D6" horizAlign="right" vertAlign="center" />
        <Label id="timeLabel" text="" color="#FFFFFF" horizAlign="right" vertAlign="center" />
        <Rectangle id="leftPanelBackground" color="#0B1626" opacity="0.82" />
        <Rectangle id="rightPanelBackground" color="#050A12" opacity="0.82" />
        <Rectangle id="divider" color="#1F324A" opacity="0.88" />
        <Label id="leftPanelTitle" text="Categorias" color="#B8C3D6" horizAlign="left" />
        <Label id="middlePanelTitle" text="Canais" color="#B8C3D6" horizAlign="left" />
        <Rectangle id="categorySectionIndicator" color="#061F36" opacity="1.0" />
        <Rectangle id="categorySectionAccent" color="#009DFF" opacity="1.0" />
        <Rectangle id="channelSectionIndicator" color="#061F36" opacity="1.0" />
        <Rectangle id="channelSectionAccent" color="#009DFF" opacity="1.0" />
        <Label id="statusLabel" text="" color="#B8C3D6" horizAlign="center" />
        <Group id="categoriesGroup" />
        <Group id="channelsGroup" />
        <Label id="hintLabel" text="↑/↓ navegar • OK selecionar/assistir • * favoritar • Voltar categorias" color="#7D8CA3" horizAlign="center" />
    </children>
</component>
