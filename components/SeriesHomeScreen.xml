        <Group id="seriesGroup" />
        <Label id="messageLabel" color="#AAB8CC" horizAlign="center" />
        <Rectangle id="selectedTitleBar" color="#061F36" opacity="0.0" />
        <Label id="selectedTitleLabel" color="#FFFFFF" horizAlign="center" vertAlign="center" />
        <Label id="hintLabel" text="OK = Abrir • ←/→ Trocar painel • VOLTAR = Home" color="#7D8CA3" horizAlign="center" />
