<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesHomeScreen" extends="Group">
    <interface>
        <function name="show" />
        <function name="hide" />
        <function name="setCategories" />
        <function name="setSeries" />
        <function name="setLoading" />
        <function name="showMessage" />
        <function name="resetSelection" />
        <function name="focusSearchEntry" />
        <field id="backRequested" type="boolean" alwaysNotify="true" />
        <field id="categorySelected" type="assocarray" alwaysNotify="true" />
        <field id="searchRequested" type="boolean" alwaysNotify="true" />
        <field id="seriesSelected" type="assocarray" alwaysNotify="true" />
